# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Use OpenAI-compatible endpoint
# OPENAI_COMPAT_API_KEY=your_key
# OPENAI_COMPAT_BASE_URL=https://your-endpoint/v1
